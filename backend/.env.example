# Server
PORT=5000
APP_NAME=KYC Automation API
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/kyc_automation_db

# Secrets — REQUIRED in production; the app refuses to boot without them.
# In development, deterministic dev fallbacks are used (with a console warning).
# WARNING: PAN_HASH_SECRET is permanent once real data exists; changing it
# breaks duplicate-PAN detection for every existing row.
PAN_HASH_SECRET=
KYC_LINK_SECRET=
JWT_SECRET=
ENCRYPTION_KEY=
WEBHOOK_SECRET=

# Auth
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL_DAYS=7

# KYC link settings
KYC_LINK_EXPIRY_DAYS=30
KYC_BUYER_BASE_URL=https://localhost:5173
KYC_API_BASE_URL=https://localhost:5000

# CORS (comma-separated origins)
CORS_ORIGIN=https://localhost:5173

# Email (Dial2Verify gateway, called directly from Node)
# EMAIL_ENABLED=false logs emails as "simulated" instead of sending.
EMAIL_ENABLED=false
EMAIL_PROVIDER_URL=http://api.dial2verify.com/v2.5/sendMail_SMTP.php
EMAIL_FROM=no-reply@2factor.in

# Reminders
REMINDER_SCHEDULER_ENABLED=true

# Live flow log (dev tool) — writes every request + DB operation to
# backend/logs/flow.log. Auto-disabled in production. Tail it to watch the flow:
#   PowerShell:  Get-Content backend/logs/flow.log -Wait -Tail 50
#   bash:        tail -f backend/logs/flow.log
FLOW_LOG_ENABLED=true
FLOW_LOG_SQL=true          # also log raw SQL + params (set false for a cleaner, ORM-only log)
FLOW_LOG_FILE=flow.log

# PAN-card validation (external Hugging Face recognizer)
# Gates PAN-document uploads: a real PAN card must be recognized before the
# image is saved. Disable for the synthetic e2e smoke test.
PAN_VALIDATION_ENABLED=true
PAN_VALIDATION_URL=https://aryans3-2fakyc.hf.space/analyze-pan?include_full_pan=true
# On network/timeout errors: true = allow upload (flag for reviewer), false = block + ask retry
PAN_VALIDATION_FAIL_OPEN=true
# true = reject when the card's PAN number does not match the KYC's PAN
PAN_MATCH_STRICT=false

# Seed (first admin user — change the password after first login)
SEED_ADMIN_EMAIL=admin@2factor.local
SEED_ADMIN_PASSWORD=Admin@12345
